# ── Tollysplit self-host configuration ──────────────────────────────────────
# Copy to `.env` (same folder), then: docker compose up -d --build
#
# ⚠️  The JWT secret + anon/service keys below are PUBLIC Supabase demo values.
#     They're fine for trying it out on your own machine. For ANY real or
#     internet-exposed deployment you MUST change JWT_SECRET and regenerate the
#     ANON_KEY / SERVICE_ROLE_KEY (instructions in selfhost/README.md), and
#     change the two passwords.

# Where the browser reaches the app (and the auth Site URL).
SITE_URL=http://localhost:3000

# Postgres superuser password (also used by PostgREST's authenticator role).
POSTGRES_PASSWORD=change-me-postgres-password

# JWT signing secret shared by GoTrue (auth) and PostgREST (min 32 chars).
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Anon + service keys — JWTs signed with JWT_SECRET. Regenerate if you change it.
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.F_rDxRTPE8OU83L_CNgEGXfmirMXmMMugT29Cvc8ygQ
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.5z-pJI1qwZg1LE5yavGLqum65WOnnaaI5eZ3V00pLww

# Optional: WalletConnect / Reown project id (enables the crypto pay buttons).
# Free from cloud.reown.com. Leave blank to disable — QR + copy still work.
REOWN_PROJECT_ID=
