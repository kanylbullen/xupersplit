# Copy to .env.local and fill in your own Supabase project values.
# Both are safe to expose in the client bundle (publishable/anon credentials);
# security relies on RLS + RPCs, not on hiding these.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
